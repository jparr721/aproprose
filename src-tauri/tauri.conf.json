{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "aproprose",
  "version": "0.5.0",
  "identifier": "com.jsp.aproprose",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "aproprose",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE4ODE1ODA0MTIxRDMwNzUKUldSMU1CMFNCRmlCcUIvQnVKOEY2TEVIU2hEWTBvWWhjRWo1S25qZDhTMDBKUUIwSFN1dGNORjkK",
      "endpoints": [
        "https://github.com/jparr721/aproprose/releases/latest/download/latest.json"
      ]
    }
  }
}
